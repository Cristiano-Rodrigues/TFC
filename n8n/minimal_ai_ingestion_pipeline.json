    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const text = $json.data || JSON.stringify($json);\nreturn { text };"
      },
      "id": "code-1",
      "name": "Normalize Text",
      "position": [
        400,
        0
      ],
      "type": "n8n-nodes-base.code",
      "typeVersion": 1
    },
    {
      "parameters": {
        "jsCode": "const text = $json.text;\nconst size = 500;\n\nlet chunks = [];\n\nfor (let i = 0; i < text.length; i += size) {\n  chunks.push({\n    pageContent: text.slice(i, i + size)\n  });\n}\n\nreturn chunks;"
      },
      "id": "code-2",
      "name": "Chunking Node",
      "position": [
        608,
        0
      ],
      "type": "n8n-nodes-base.code",
      "typeVersion": 1
    },
