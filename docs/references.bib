  doi = {10.59776/rter.v3i1.5284},
  urldate = {2026-07-14},
  abstract = {O governo eletr\^onico \'e uma das principais preocupa\c c\~oes dos estados que pretendem se modernizar. Esse fato imp\~oe aos governos a buscarem alternativas de recursos tecnol\'ogicos mais eficientes que sustentem a transforma\c c\~ao digital da administra\c c\~ao p\'ublica na presta\c c\~ao de servi\c cos de qualidade. Este trabalho visa analisar a experi\^encia angolana na implementa\c c\~ao do governo eletr\^onico, sobretudo, identificar os portais governamentais como instrumentos relativos \`a participa\c c\~ao dos cidad\~aos e descrever os desafios e perspectivas do setor p\'ublico angolano com a introdu\c c\~ao do governo eletr\^onico. Metodologicamente, para o desenvolvimento do estudo adotou-se uma abordagem de natureza qualitativa, coletando dados atrav\'es de pesquisa documental. Foram selecionados documentos nos portais governamentais e de \'org\~aos internacionais. Como t\'ecnica de an\'alise, nos subsidiamos na an\'alise de conte\'udo. Os resultados encontrados apontam para a exist\^encia de limita\c c\~oes na implementa\c c\~ao do governo eletr\^onico no contexto angolano, nomeadamente, a necessidade de investimento em recursos tecnol\'ogicos, desenvolvimento de a\c c\~oes de melhoria cont\'inua na presta\c c\~ao servi\c cos p\'ublicos e proporcionar a inclus\~ao social e digital dos cidad\~aos, destacando a\c c\~oes de e-democracia e e-participa\c c\~ao.},
  file = {/home/cristiano/Zotero/storage/FZ9X68VR/Quiala and Caetano - 2023 - GOVERNO ELETRÔNICO UMA ANÁLISE DA EXPERIÊNCIA ANGOLANA.pdf}
}

