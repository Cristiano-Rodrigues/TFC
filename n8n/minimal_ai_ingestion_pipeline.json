    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const text = $json.data || JSON.stringify($json);\nreturn { text };"
      },
      "id": "code-1",
      "name": "Normalize Text",
      "position": [
        400,
        0
      ],
      "type": "n8n-nodes-base.code",
      "typeVersion": 1
    },
    {
      "parameters": {
        "jsCode": "const text = $json.text || '';\nconst webhookData = $('Upload webhook').first().json || {};\nconst document_id = webhookData.body?.document_id || webhookData.document_id || null;\n// The file name is usually in binary metadata, but let's try to get it if passed or default to Desconhecido\nconst filename = webhookData.body?.filename || webhookData.filename || 'Desconhecido';\n\nconst size = 500;\nlet chunks = [];\n\nfor (let i = 0; i < text.length; i += size) {\n  chunks.push({\n    pageContent: text.slice(i, i + size),\n    document_id: document_id,\n    metadata: {\n      filename: filename\n    }\n  });\n}\n\nreturn chunks;"
      },
